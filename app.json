  "name": {
    "en": "Pioneer Legacy"
  },
  "description": {
    "en": "Simple Homey integration for the Pioneer Legacy AV receiver with power, volume and input control."
  },
  "category": [
    "appliances"
  ],
  "brandColor": "#000000",
  "permissions": [],
  "images": {
    "small": "/assets/images/small.png",
