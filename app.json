    "xlarge": "/assets/images/xlarge.png"
  },
  "author": {
    "name": "arnoud hageman",
    "email": "a_hahaha@hotmail.com"
  },
  "flow": {
    "actions": [
      {
        "title": {
          "en": "Send debug command",
          "nl": "Stuur debug-opdracht"
        },
        "titleFormatted": {
          "en": "Send debug command [[command]]",
          "nl": "Stuur debug-opdracht [[command]]"
        },
        "hint": {
          "en": "Sends a custom raw Pioneer command and returns the response as a Homey notification.",
          "nl": "Stuurt een ruwe Pioneer-opdracht en geeft het antwoord terug als Homey-melding."
        },
        "args": [
          {
            "name": "command",
            "type": "text",
            "title": {
              "en": "Command",
              "nl": "Opdracht"
            },
            "placeholder": {
              "en": "?P",
              "nl": "?P"
            }
          }
        ],
        "id": "debug_command"
      },
      {
        "title": {
          "en": "Diagnose source",
          "nl": "Diagnose bron"
        },
        "hint": {
          "en": "Reads only the raw source response from the Pioneer receiver and sends it as a Homey notification.",
          "nl": "Leest alleen het ruwe bron-antwoord van de Pioneer receiver uit en stuurt dit als Homey-melding."
        },
        "id": "diagnose_source"
      },
      {
        "title": {
          "en": "Diagnose Pioneer",
          "nl": "Diagnose Pioneer"
        },
        "hint": {
          "en": "Reads raw Pioneer status responses and sends them as a Homey notification.",
          "nl": "Leest ruwe Pioneer-statusantwoorden uit en stuurt ze als Homey-melding."
        },
        "id": "diagnose_status"
      },
      {
        "title": {
          "en": "Select listening mode",
          "nl": "Selecteer luistermodus"
        },
        "titleFormatted": {
          "en": "Select listening mode [[listening_mode]]",
          "nl": "Selecteer luistermodus [[listening_mode]]"
        },
        "hint": {
          "en": "Sets the listening mode of the Pioneer receiver.",
          "nl": "Stelt de luistermodus van de Pioneer-versterker in."
        },
        "args": [
          {
            "name": "listening_mode",
            "type": "dropdown",
            "values": [
